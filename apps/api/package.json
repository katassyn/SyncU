{
	"name": "@syncu/api",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"module": "src/index.ts",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --target bun --outdir dist",
		"db:generate": "drizzle-kit generate --config=drizzle.config.ts",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:studio": "drizzle-kit studio --config=drizzle.config.ts",
		"test": "bun test",
		"test:e2e": "bun test --pattern '*.e2e.ts'",
		"typecheck": "tsc --noEmit",
		"lint": "eslint ."
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.2",
		"@syncu/core": "workspace:*",
		"@syncu/types": "workspace:*",
		"cheerio": "^1.2.0",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.1.0",
		"logixlysia": "^6.3.1",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"bun-types": "^1.3.13",
		"drizzle-kit": "^0.31.10",
		"typescript": "~6.0.2"
	}
}
