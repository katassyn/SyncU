{
  "name": "syncu",
  "private": true,
  "version": "0.0.0",
  "description": "SyncU - Synchronise University (monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "dev:web": "bun run --filter=@syncu/web dev",
    "dev:api": "bun run --filter=@syncu/api dev",
    "build": "bun run --filter='*' build",
    "lint": "bun run --filter='*' lint",
    "test": "bun run --filter='*' test",
    "db:migrate": "bun run --filter=@syncu/api db:migrate"
  },
  "packageManager": "bun@1.1.0",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
